# ─── Phiên bản n8n ────────────────────────────────────────────────────────────
VERSION=latest
CONTAINER_NAME=n8n_dtp

# ─── Network / Host ───────────────────────────────────────────────────────────
HOST_IP=127.0.0.1
WEB_HTTP_PORT=5678

# ─── Resource limits (0 = không giới hạn) ─────────────────────────────────────
CPUS=0
MEMORY_LIMIT=0MB
WORKER_CPUS=2
WORKER_MEMORY=2GB

# ─── App path trên host ────────────────────────────────────────────────────────
APP_PATH=/www/dk_project/dk_app/n8n/n8n_dtp

# ─── n8n core ──────────────────────────────────────────────────────────────────
N8N_HOST=n8n.xxxx.com.vn
N8N_PROTOCOL=https
WEBHOOK_URL=https://n8n.xxxx.com.vn/
GENERIC_TIMEZONE=Asia/Ho_Chi_Minh

# QUAN TRỌNG: phải giống nhau trên main và tất cả worker
N8N_ENCRYPTION_KEY=change-me-to-a-random-32-char-key

# ─── Queue mode ────────────────────────────────────────────────────────────────
EXECUTIONS_MODE=queue
N8N_GRACEFUL_SHUTDOWN_TIMEOUT=30
OFFLOAD_MANUAL_EXECUTIONS_TO_WORKERS=true

# ─── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=n8n
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=n8n
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=change-me-redis-password

# ─── Worker ───────────────────────────────────────────────────────────────────
WORKER_COUNT=2
WORKER_CONCURRENCY=10

# ─── Health check ─────────────────────────────────────────────────────────────
QUEUE_HEALTH_CHECK_ACTIVE=true

# ─── Metrics (Prometheus) ─────────────────────────────────────────────────────
N8N_METRICS=false

# ─── Email / SMTP ─────────────────────────────────────────────────────────────
N8N_EMAIL_MODE=smtp
N8N_SMTP_HOST=smtp.gmail.com
N8N_SMTP_PORT=465
N8N_SMTP_USER=services.xxxx@gmail.com
N8N_SMTP_PASS=xxxxx
N8N_SMTP_SENDER=DTP N8N <services.xxxx@gmail.com>

# ─── Bảo mật / Misc ───────────────────────────────────────────────────────────
N8N_SECURE_COOKIE=false
N8N_PROXY_HOPS=1
NODEJS_PREFER_IPV4=true
N8N_ENFORCE_SETTINGS_FILE_PERMISSIONS=false
N8N_DIAGNOSTICS_ENABLED=false

# ─── Credentials overwrite ────────────────────────────────────────────────────
CREDENTIALS_OVERWRITE_DATA={"googleOAuth2Api":{"clientId":"xxx.googleusercontent.com","clientSecret":"xxxxx"}}

# ─── User folder ──────────────────────────────────────────────────────────────
N8N_USER_FOLDER=/home/node
